{
  "name": "Playwright Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/playwright:1": {
      "installBrowsers": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-playwright.playwright"]
    }
  },
  "postCreateCommand": "pip install playwright"
}
